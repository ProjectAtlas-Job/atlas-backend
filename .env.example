COOKIE_DOMAIN=
LOG_LEVEL=INFO
LOG_DIR=logs
SYSTEM_SMTP_HOST=smtp.gmail.com
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=your-gmail-address@gmail.com
SYSTEM_SMTP_PASSWORD=your-16-character-app-password
SYSTEM_FROM_EMAIL=your-gmail-address@gmail.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
